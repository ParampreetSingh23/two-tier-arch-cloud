# Copy this file to .env and fill in your EC2 public IP/domain

# The public URL your backend API is reachable at (used by the React build)
VITE_API_URL=http://<EC2_PUBLIC_IP>:5001/api

# The public URL your frontend is served at (used by the server for CORS)
CLIENT_URL=http://<EC2_PUBLIC_IP>

# Optional – email credentials for password-reset functionality
EMAIL_USER=
EMAIL_PASS=
